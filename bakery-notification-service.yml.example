# Server Configuration
server:
  port: 8087

# Spring Application Configuration
spring:
  datasource:
    driver-class-name: org.postgresql.Driver
    hikari:
      maximum-pool-size: 10
      minimum-idle: 5
      idle-timeout: 300000
      connection-timeout: 20000

  jpa:
    hibernate:
      naming:
        physical-strategy: org.hibernate.boot.model.naming.PhysicalNamingStrategyStandardImpl
    database-platform: org.hibernate.dialect.PostgreSQLDialect

  mail:
    host: smtp.gmail.com
    port: 587
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true
            required: true
          connectiontimeout: 5000
          timeout: 5000
          writetimeout: 5000

  thymeleaf:
    prefix: classpath:/templates/
    suffix: .html
    mode: HTML
    encoding: UTF-8
    check-template-location: true
    cache: false

  cache:
    type: simple
    cache-names: templates, users, settings

  jackson:
    default-property-inclusion: NON_NULL
    serialization:
      write-dates-as-timestamps: false

  kafka:
    consumer:
      group-id: notification-service-group
      auto-offset-reset: earliest
      key-deserializer: org.apache.kafka.common.serialization.StringDeserializer
      value-deserializer: org.springframework.kafka.support.serializer.ErrorHandlingDeserializer
      properties:
        spring.deserializer.value.delegate.class: org.springframework.kafka.support.serializer.JsonDeserializer
        spring.json.trusted.packages: "org.devofblue.common.event"

  docker:
    compose:
      file: docker-compose-notifications-db.yml
      enabled: false

# Eureka Client Configuration
eureka:
  client:
    register-with-eureka: true
    fetch-registry: true
  instance:
    prefer-ip-address: true
    instance-id: ${spring.application.name}:${server.port}
    lease-renewal-interval-in-seconds: 30
    lease-expiration-duration-in-seconds: 90

# Feign Configuration
feign:
  client:
    config:
      default:
        connectTimeout: 5000
        readTimeout: 5000
        loggerLevel: basic

# Management & Actuator Configuration
management:
  endpoints:
    web:
      exposure:
        include: health, info, metrics, scheduledtasks, refresh
      base-path: /actuator
  endpoint:
    health:
      show-details: always
  metrics:
    tags:
      application: ${spring.application.name}

# Notification Service Specific Configuration
notification:
  email:
    from-name: "Shah's Bakery"
    enabled: true
    retry-attempts: 3
    retry-delay-minutes: 5

  sms:
    retry-attempts: 3
    retry-delay-minutes: 2

  push:
    provider: "aws-sns"
    retry-attempts: 3
    retry-delay-minutes: 1
    time-to-live: 3600  # 1 hour in seconds
    collapse-key: "bakery-notification"
    default-sound: "default"
    badge-count: 1

  templates:
    cache-ttl-minutes: 60
    reload-on-change: true

  scheduling:
    enabled: true
    abandoned-cart-delay-hours: 2
    follow-up-delay-hours: 24
    cleanup-days: 90

  rate-limit:
    email-per-minute: 100
    sms-per-minute: 50
    push-per-minute: 1000

# External Service URLs
external-services:
  user-service:
  order-service:
  cart-service:

---
spring:
  config:
    activate:
      on-profile: dev

  datasource:
    url: jdbc:postgresql://your-db-host:5432/bakery_notifications
    username: your_db_user
    password: your_db_password

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        use_sql_comments: true

  mail:
    username: your_db_user
    password: your_db_password

  kafka:
    bootstrap-servers: localhost:9092

eureka:
  client:
    service-url:
      defaultZone: http://localhost:8761/eureka/

aws:
  region: us-east-1
  access-key: your_access_key
  secret-key: your_secret_key
  sns:
    android-platform-arn: arn:aws:sns:us-east-1:123456789:app/FCM/YourBakeryApp-Android
    general-topic-arn: arn:aws:sns:us-east-1:123456789:bakery-general-notifications
    marketing-topic-arn: arn:aws:sns:us-east-1:123456789:bakery-marketing
    orders-topic-arn: arn:aws:sns:us-east-1:123456789:bakery-orders

brevo:
  api-key: your_api_key

notification:
  email:
    from: noreply@shahs-bakery.com
    reply-to: support@shahs-bakery.com
  sms:
    account-sid: your-twilio-sid
    auth-token: your-twilio-token
    from-number: +1234567890
    enabled: false
  push:
    enabled: false

logging:
  level:
    com.shah_s.bakery_notification_service: DEBUG
    software.amazon.awssdk: INFO
    org.springframework.web: DEBUG
    org.springframework.mail: DEBUG
    com.twilio: INFO
    root: INFO
  pattern:
    console: "%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"
    file: "%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{50} - %msg%n"
  file:
    name: logs/notification-service.log
  logback:
    rollingpolicy:
      max-file-size: 10MB
      max-history: 30

---
spring:
  config:
    activate:
      on-profile: prod

  datasource:
    url: ${NOTIFICATION_DB_URL}
    username: your_db_user
    password: your_db_password

  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: false

  mail:
    username: your_db_user
    password: your_db_password

  kafka:
    bootstrap-servers: ${KAFKA_BOOTSTRAP_SERVERS}

eureka:
  client:
    service-url:
      defaultZone: ${EUREKA_URL}

aws:
  region: ${AWS_REGION}
  access-key: your_access_key
  secret-key: your_secret_key
  sns:
    android-platform-arn: ${AWS_SNS_ANDROID_PLATFORM_ARN}
    general-topic-arn: ${AWS_SNS_GENERAL_TOPIC_ARN}
    marketing-topic-arn: ${AWS_SNS_MARKETING_TOPIC_ARN}
    orders-topic-arn: ${AWS_SNS_ORDERS_TOPIC_ARN}

brevo:
  api-key: your_api_key

notification:
  email:
    from: ${NOTIFICATION_FROM_EMAIL}
    reply-to: ${NOTIFICATION_REPLY_TO}
  sms:
    account-sid: ${TWILIO_ACCOUNT_SID}
    auth-token: ${TWILIO_AUTH_TOKEN}
    from-number: ${TWILIO_FROM_NUMBER}
    enabled: ${SMS_ENABLED}
  push:
    enabled: ${PUSH_ENABLED}

logging:
  level:
    com.shah_s.bakery_notification_service: INFO
    software.amazon.awssdk: INFO
    org.springframework.web: INFO
    org.springframework.mail: INFO
    com.twilio: INFO
    root: INFO
  pattern:
    console: "%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"
    file: "%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{50} - %msg%n"
  file:
    name: logs/notification-service.log
  logback:
    rollingpolicy:
      max-file-size: 10MB
      max-history: 30
